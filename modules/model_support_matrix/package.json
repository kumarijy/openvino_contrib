{
  "name": "openvino-model-support-matrix",
  "version": "1.0.0",
  "type": "module",
  "description": "OpenVINO GenAI Model Support Matrix - Interactive web application for tracking model support across OpenVINO releases",
  "main": "src/index.tsx",
  "scripts": {
    "start": "webpack serve --mode development --open",
    "start:server": "node server/index.js",
    "start:dev": "concurrently \"npm run start\" \"npm run start:server\"",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "lint": "eslint --ext .ts,.tsx src/",
    "type-check": "tsc --noEmit",
    "validate": "node --loader tsx scripts/validate-data.ts"
  },
  "keywords": [
    "openvino",
    "genai",
    "models",
    "support-matrix",
    "ai",
    "machine-learning"
  ],
  "author": "OpenVINO Contrib",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "autoprefixer": "^10.4.17",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.10.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "html-webpack-plugin": "^5.6.0",
    "postcss": "^8.4.35",
    "postcss-loader": "^8.1.1",
    "style-loader": "^3.3.4",
    "tailwindcss": "^3.4.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "dependencies": {
    "@heroicons/react": "^2.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "node-fetch": "^3.3.2",
    "concurrently": "^8.2.2"
  }
}
