# Jira API Configuration
# Copy this file to .env and fill in your credentials

# Your Intel Jira instance base URL
JIRA_BASE_URL=https://jira.devtools.intel.com

# Your Intel email address (used for Jira authentication)
JIRA_EMAIL=your.email@intel.com

# Your Jira API Token
# Generate at: https://jira.devtools.intel.com/secure/ViewProfile.jspa
# Look for "Personal Access Tokens" or "API Tokens" section
JIRA_API_TOKEN=your_jira_api_token_here

# Jira Project Key (default: CVS for OpenVINO)
JIRA_PROJECT_KEY=CVS

# Backend server port (default: 3001)
PORT=3001
